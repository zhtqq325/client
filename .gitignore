# ============================================
# Node.js 项目忽略规则
# ============================================

# 依赖目录 - 绝对不能上传
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 运行时生成的日志文件
logs
*.log

# 运行时数据
pids
*.pid
*.seed
*.pid.lock

# 测试覆盖率报告
coverage/
.nyc_output/

# 构建输出目录
dist/
build/
out/

# Electron 构建输出
release/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.msi

# ============================================
# 编辑器/IDE 忽略规则
# ============================================

# VS Code
.vscode/
*.code-workspace

# WebStorm/IntelliJ
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#

# ============================================
# 操作系统忽略规则
# ============================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.nfs*

# ============================================
# 环境变量和敏感信息
# ============================================

# 环境变量文件
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# 密钥文件
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# ============================================
# 临时文件和缓存
# ============================================

# 临时文件
tmp/
temp/
*.tmp
*.temp

# 缓存目录
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ============================================
# 项目特定忽略规则
# ============================================

# 本地服务器日志
local-server.log

# 测试生成的文件
test-output/
screenshots/

# 用户数据（如果有）
user-data/
userdata/
